{
  "$schema": "https://opencode.ai",
  "plugin": ["llama-router"],
  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (Local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "local",
        "toolParser": [
          { "type": "raw-function-call" },
          { "type": "json" }
        ]
      },
      "models": {
        "meu-modelo-local": {
          "name": "Modelo Local Llama.cpp",
          "tool_call": true
        }
      }
    }
  }
}
