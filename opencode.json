{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@mailshieldai/opencode-canvas",
    "@nick-vi/opencode-type-inject",
    "@tarquinen/opencode-dcp",
    "opencode-websearch-cited@1.2.0",
    "opencode-notificator",
    "kdco/workspace",
    "octto",
    "opentmux",
    "opencode-plugin-llama.cpp@latest"
  ],
  "permission": {
    "canvas_*": "allow"
  },
  "mcp": {
 
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "azure-devops": {
      "type": "local",
      "command": ["npx", "-y", "@azure-devops/mcp"],
      "enabled": true
    },
    "microsoft-docs": {
      "type": "remote",
      "url": "https://learn.microsoft.com/api/mcp",
      "enabled": true
    },
    "duckduckgo": {
      "type": "local",
      "command": ["uvx", "duckduckgo-mcp-server"],
      "enabled": true
    }
  },
  "provider": {
    "llamacpp-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (Local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "local",
        "toolParser": [
          { "type": "raw-function-call" },
          { "type": "json" }
        ]
      },
      "models": {
        "Gemma-4-12B-IT": {
          "name": "Gemma 4 12B IT",
          "tool_call": true
        },
        "Gemma-4-26B-A4B-IT": {
          "name": "Gemma 4 26B A4B IT",
          "tool_call": true
        },
        "Qwen3.5-9B-MTP": {
          "name": "Qwen 3.5 9B MTP",
          "tool_call": true
        },
        "Qwen3.6-27B-MTP": {
          "name": "Qwen 3.6 27B MTP",
          "tool_call": true
        },
        "Qwen3.6-35B-A3B-MTP-KV-Cache-q8": {
          "name": "Qwen 3.6 35B A3B MTP KV Cache q8",
          "tool_call": true
        },
        "unsloth/Qwen3.5-9B-MTP-GGUF:Q5_K_XL": {
          "name": "Qwen 3.5 9B MTP GGUF Q5_K_XL",
          "tool_call": true
        },
        "unsloth/Qwen3.6-35B-A3B-MTP-GGUF:IQ4_NL": {
          "name": "Qwen 3.6 35B A3B MTP GGUF IQ4_NL",
          "tool_call": true
        }
      }
    },
    "llamacpp-remote": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (Remote - miztorvi)",
      "options": {
        "baseURL": "https://llama.miztorvi.com/v1",
        "apiKey": "${LLAMACPP_API_KEY}",
        "toolParser": [
          { "type": "raw-function-call" },
          { "type": "json" }
        ]
      },
      "models": {
        "meu-modelo-remote": {
          "name": "Modelo Remote Llama.cpp (miztorvi)",
          "tool_call": true
        }
      }
    },
    "google": {
      "type": "api",
      "options": {
        "websearch_cited": {
          "model": "gemini-2.5-flash"
        }
      }
    }
  }
}
