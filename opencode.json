{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@mailshieldai/opencode-canvas",
    "@nick-vi/opencode-type-inject",
    "@tarquinen/opencode-dcp",
    "opencode-websearch-cited@1.2.0",
    "opencode-notificator",
    "kdco/workspace",
    "octto",
    "opentmux",
    "opencode-plugin-llama.cpp@latest"
  ],
  "permission": {
    "canvas_*": "allow"
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp", "--api-key", "YOUR_API_KEY"],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "docker": {
      "type": "remote",
      "url": "https://mcp.miztorvi.com/docker/sse",
      "headers": {
        "X-API-Key": "GlVJgDqNXzdyweb6H6cdagRTDk+nPVjh1xnwbitpI90="
      },
      "enabled": true
    }
  },
  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (Local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "local",
        "toolParser": [
          { "type": "raw-function-call" },
          { "type": "json" }
        ]
      },
      "models": {
        "meu-modelo-local": {
          "name": "Modelo Local Llama.cpp",
          "tool_call": true
        }
      }
    },
    "google": {
      "type": "api",
      "options": {
        "websearch_cited": {
          "model": "gemini-2.5-flash"
        }
      }
    }
  }
}
